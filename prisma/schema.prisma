generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  password      String?
  image         String?
  role          Role      @default(USER)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  listings      Listing[]       @relation("UserListings")
  savedListings SavedListing[]  @relation("UserSavedListings")
  reviews       Review[]        @relation("UserReviews")
}

// Required by Auth.js Prisma Adapter for OAuth providers
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

enum Role {
  USER
  OWNER
  ADMIN
}

enum ListingStatus {
  ACTIVE
  DRAFT
  RENTED
}

// ─── New Enums ───────────────────────────────────────────────────────────────

enum RoomType {
  SINGLE
  SHARED
  PG
  FLAT
}

enum GenderPreference {
  MALE
  FEMALE
  ANY
}

enum Furnishing {
  FURNISHED
  SEMI_FURNISHED
  UNFURNISHED
}

// ─── Listing ─────────────────────────────────────────────────────────────────

model Listing {
  id               String           @id @default(cuid())
  ownerId          String
  title            String
  description      String
  city             String
  locality         String
  address          String?
  pincode          String?
  monthlyRent      Int
  deposit          Int?
  roomType         RoomType
  genderPreference GenderPreference @default(ANY)
  furnishing       Furnishing
  status           ListingStatus    @default(DRAFT)
  isAvailable      Boolean          @default(false)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  owner     User             @relation("UserListings", fields: [ownerId], references: [id], onDelete: Cascade)
  images    ListingImage[]
  amenities ListingAmenity[]
  saves     SavedListing[]   @relation("ListingSaves")
  reviews   Review[]         @relation("ListingReviews")

  @@index([city, locality])
  @@index([monthlyRent])
  @@index([roomType])
  @@index([isAvailable])
}

// ─── ListingImage ─────────────────────────────────────────────────────────────

model ListingImage {
  id        String   @id @default(cuid())
  listingId String
  url       String
  publicId  String?  // Cloudinary public ID for cleanup
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)
}

// ─── Amenity ──────────────────────────────────────────────────────────────────

model Amenity {
  id       String           @id @default(cuid())
  name     String           @unique
  icon     String?
  listings ListingAmenity[]
}

// ─── ListingAmenity (junction) ────────────────────────────────────────────────

model ListingAmenity {
  listingId String
  amenityId String

  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  amenity Amenity @relation(fields: [amenityId], references: [id], onDelete: Cascade)

  @@id([listingId, amenityId])
}

// ─── SavedListing ─────────────────────────────────────────────────────────────

model SavedListing {
  userId    String
  listingId String
  createdAt DateTime @default(now())

  user    User    @relation("UserSavedListings", fields: [userId], references: [id], onDelete: Cascade)
  listing Listing @relation("ListingSaves", fields: [listingId], references: [id], onDelete: Cascade)

  @@id([userId, listingId])
}

// ─── Review ───────────────────────────────────────────────────────────────────

model Review {
  id        String   @id @default(cuid())
  listingId String
  userId    String
  rating    Int      // TODO: add CHECK (rating >= 1 AND rating <= 5) via raw SQL in migration
  comment   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  listing Listing @relation("ListingReviews", fields: [listingId], references: [id], onDelete: Cascade)
  user    User    @relation("UserReviews", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([listingId, userId])
}